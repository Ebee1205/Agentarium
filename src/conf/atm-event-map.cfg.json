{
  "atm_mw_server": {
    "rmq": {
      "send.frame": {
        "queue": "atm-queue",
        "handler": "src.service.system.system_consumer.handle_system_message",
        "description": "포즈 데이터 수집 및 처리"
      }
    }
  },
  "atm_web_server": {
    "ws": {
      "chat.message": {
        "websocket": "/v1/session/chat",
        "handler": "src.service.ai.chat_ws.handle_llm_invocation",
        "description": "사용자 채팅 메시지 처리 (LLM 경유)"
      },
      "llm.invoke": {
        "websocket": "/v1/session/chat",
        "handler": "src.service.ai.chat_ws.handle_llm_invocation",
        "description": "LLM 호출 요청 처리"
      },
      "typing": {
        "websocket": "/v1/session/chat",
        "handler": "src.service.messaging.ws_processor.process_typing_indicator",
        "description": "사용자 입력 중 표시"
      }
    },
    "redis": {
      "session:chat:*": {
        "stream_key": "session:chat:*",
        "description": "세션별 채팅 메시지 저장소"
      }
    }
  }
}
