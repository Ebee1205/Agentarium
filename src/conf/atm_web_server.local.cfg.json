{
    "environment": "local",
    "project_name": "atm_web_server",
    "api_v1_str": "/api/v1",
    "host": "localhost",
    "port": 3000,
    "secret_key": "changethis-secret-key",
    "access_token_expire_minutes": 1440,

    "http_config": {
      "allow_origins": ["http://localhost:3000"],
      "allow_methods": ["*"],
      "allow_headers": ["*"],
      "allow_credentials": true
    },

    "rmq": {
      "host": "localhost",
      "port": 5672,
      "user": "guest",
      "password": "guest",
      "queues": [
        { "name": "atm-queue", "type": "pub" }
      ]
    },
    
    "db": {
      "host": "localhost",
      "port": 3306,
      "user": "guest",
      "password": "abcd1234",
      "database": "atm"
    },
    
    "redis": {
      "host": "localhost",
      "port": 6379,
      "db": 0,
      "password": null
    },

    "redis_consumer": {
      "stream_key": "session:chat:*",
      "group_name": "web-group",
      "consumer_name": "web-consumer-1"
    },

    "r2": {
      "account_id": "atm-images",
      "bucket_name": "atm-images",
      "region": "auto",
      "endpoint_url": "https://2a9b33fa7ea08ae491598e555233bddb.r2.cloudflarestorage.com",
      "public_base_url": "https://pub-a309ad8a0a6e4a629ad982d710e35276.r2.dev",
      "image_prefix": "images",
      "upload_url_expire_seconds": 900
    },

    "logger": {
        "level": "debug",
        "path": "./logs/atm_web_server.log-%DATE%",
        "suffix": "%Y-%m-%d",
        "max_bytes": 10485760,
        "max_files": "3d",
        "rotation": "daily",
        "use_console": true
    }  
}
  