{
  "environment": "local",
  "project_name": "atm",
  "api_v1_str": "/api/v1",
  "host": "0.0.0.0",
  "port": 9571,
  "secret_key": "atm-local-development-key",
  "access_token_expire_minutes": 60,
  "logger": {
    "level": "DEBUG",
    "path": "logs/atm.log",
    "suffix": "%Y%m%d",
    "max_bytes": 10485760,
    "max_files": "7",
    "rotation": "midnight",
    "use_console": true
  },
  "http_config": {
    "allow_origins": ["*"],
    "allow_methods": ["*"],
    "allow_headers": ["*"],
    "allow_credentials": false
  },
  "enable_monitoring": false,
  "monitoring_interval": 10,
  "llm": {
    "provider": "ollama",
    "model": "kwangsuklee/Qwen3.5-9B-Claude-4.6-Opus-Reasoning-Distilled-GGUF:latest",
    "base_url": "http://127.0.0.1:11434",
    "timeout_seconds": 6000,
    "api_key_env": null
  },
  "rag": {
    "enabled": false,
    "chunks_path": "reference/atm_chunks.json",
    "index_path": "faiss_index_chunks",
    "embedding_model": "nomic-embed-text",
    "embedding_base_url": "http://127.0.0.1:11434"
  },
  "terrarium": {
    "enabled": true,
    "tick_seconds": 3.0,
    "max_events": 200,
    "auto_start": false,
    "default_simulation_id": "atm-demo",
    "use_llm": true,
    "prompt_path": "src/service/prompts/agent_action.txt",
    "max_memories": 10,
    "ticks_per_day": 24,
    "day_start_hour": 6,
    "night_start_hour": 18,
    "initial_food": 30,
    "initial_water": 30,
    "hunger_per_tick": 2,
    "energy_day_cost": 1,
    "energy_night_cost": 2
  }
}
