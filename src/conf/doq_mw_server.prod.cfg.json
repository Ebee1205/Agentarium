{
    "environment": "local",
    "project_name": "doq_mw_server",
    "api_v1_str": "/api/v1",
    "host": "localhost",
    "port": 3000,
    "secret_key": "changethis-secret-key",
    "access_token_expire_minutes": 1440,

    "llm": {
      "provider": "ollama",
      "model": "exaone3.5:latest",
      "base_url": "http://127.0.0.1:11434",
      "timeout_seconds": 120,
      "api_key_env": null
    },

    "rag": {
      "enabled": true,
      "chunks_path": "reference/doq_chunks.json",
      "index_path": "faiss_index_chunks",
      "embedding_model": "nomic-embed-text",
      "embedding_base_url": "http://127.0.0.1:11434"
    },


    "rmq": {
      "host": "localhost",
      "port": 5672,
      "user": "guest",
      "password": "guest",
      "queues": [
        { "name": "doq-queue", "type": "sub" }
      ]
    },
    
    "db": {
      "host": "localhost",
      "port": 3306,
      "user": null,
      "password": null,
      "database": "doq"
    },

    "redis": {
      "host": "localhost",
      "port": 6379,
      "db": 1,
      "password": null
    },

    "redis_consumer": {
      "stream_key": "session:chat:*",
      "group_name": "web-group",
      "consumer_name": "web-consumer-1"
    },


    "logger": {
        "level": "debug",
        "path": "./logs/doq_mw_server.log-%DATE%",
        "suffix": "%Y-%m-%d",
        "max_bytes": 10485760,
        "max_files": "3d",
        "rotation": "daily",
        "use_console": true
    }  
}
  